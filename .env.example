# Copy this file to .env and fill in values. .env is gitignored.

# --- IBKR Gateway / TWS connection ---
# 4002 = Gateway paper, 4001 = Gateway live, 7497 = TWS paper, 7496 = TWS live
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=1

# --- Mode ---
# paper | live  (live requires --i-understand-the-risk flag at runtime)
MODE=paper

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs

# --- Risk caps (see STRATEGIES.md for authoritative values) ---
WEEKLY_LOSS_BUDGET_USD=500
PER_TRADE_RISK_CAP_USD=200
MAX_GROSS_PREMIUM_PCT_NAV=0.40
MAX_CONCURRENT_POSITIONS=2
