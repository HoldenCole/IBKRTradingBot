# Copy to .env and fill in. NEVER commit a real .env.

# --- IBKR connection ---
IBKR_HOST=127.0.0.1
IBKR_PORT=4002              # 4002=Gateway paper, 4001=Gateway live, 7497=TWS paper, 7496=TWS live
IBKR_CLIENT_ID=1

# --- Mode ---
MODE=paper                  # paper | live  (live also requires --i-understand-the-risk on CLI)

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs

# --- Risk ---
WEEKLY_LOSS_BUDGET_USD=500
PER_TRADE_RISK_CAP_USD=200
MAX_CONCURRENT_POSITIONS=2
MAX_GROSS_PREMIUM_PCT=0.60   # of NAV
SOFT_GATE_PCT=0.70           # of weekly budget -> 50% sizing
OVERNIGHT_RISK_MULTIPLIER=1.5

# --- Regime filter (external service the user owns) ---
REGIME_BASE_URL=             # leave blank to disable (fail-closed: regime treated as OFF)
REGIME_TIMEOUT_SEC=2.0

# --- Economic calendar (for blackout windows) ---
ECON_CALENDAR_PROVIDER=stub  # stub | fmp
FMP_API_KEY=                 # required when ECON_CALENDAR_PROVIDER=fmp

# --- Strategy enablement (see DECISIONS.md for v1.1 rationale) ---
EWO_ENABLED=true             # 8-year backtest: 6 trades, 50% win, -$25. Acknowledged unvalidated.
SQQQ_SHORT_ENABLED=false     # 8-year backtest: 2 trades, 0% win, -$360. Disabled by default.
